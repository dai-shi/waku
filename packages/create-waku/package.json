{
  "name": "create-waku",
  "version": "0.13.0-1.0.0-beta.6-0",
  "author": "Daishi Kato",
  "type": "module",
  "contributors": [
    "Vasu Singh"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wakujs/waku.git",
    "directory": "packages/create-waku"
  },
  "bin": {
    "create-waku": "./cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "start": "node ./dist/index.js",
    "dev": "pnpm build --watch",
    "compile": "rm -rf dist *.tsbuildinfo templates && cp -r ../../templates templates && rm -rf templates/*/node_modules templates/*/dist templates/*/.cache templates/*/*.tsbuildinfo templates/*/src/pages.gen.ts && (for d in templates/*; do mv $d/.gitignore $d/gitignore || true; done) && pnpm run build",
    "build": "tsup",
    "test": "npm_config_user_agent=pnpm vitest run"
  },
  "devDependencies": {
    "@clack/prompts": "^1.6.0",
    "@types/fs-extra": "^11.0.4",
    "@types/tar": "^7.0.87",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "picocolors": "^1.1.1",
    "tar": "^7.5.17",
    "tsup": "^8.5.1",
    "update-check": "^1.5.4",
    "vitest": "^4.1.9"
  }
}
