{
  "name": "waku-monorepo",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --filter='./packages/*' run dev",
    "compile": "pnpm -r --filter='./packages/*' run compile",
    "csb-install-FIXME": "pnpm install --no-frozen-lockfile",
    "test": "pnpm run \"/^test:.*/\"",
    "test:lint": "prettier -c . && eslint . && tsc -b && pnpm -F 07_cloudflare cf-typegen && pnpm run tsc-examples",
    "test:unit": "pnpm run -r test",
    "test-vite-ecosystem-ci": "VITE_EXPERIMENTAL_WAKU_ROUTER=true pnpm run -r --filter='!create-waku' test && VITE_EXPERIMENTAL_WAKU_ROUTER=true playwright test --project=chromium-prd --project=chromium-dev",
    "tsc-examples": "tsc -b ./examples/*/tsconfig.json ./e2e/fixtures/*/tsconfig.json ./e2e/fixtures/monorepo/packages/waku-project/tsconfig.json",
    "e2e": "playwright test",
    "e2e-dev": "playwright test --project=chromium-dev",
    "e2e-prd": "playwright test --project=chromium-prd",
    "website:dev": "pnpm -F waku-website dev",
    "website:build": "VITE_EXPERIMENTAL_WAKU_ROUTER=true pnpm -F waku-website build",
    "website:vercel": "pnpm run compile && pnpm run website:build && mkdir -p .vercel && mv packages/website/.vercel/output .vercel/ && node packages/website/patch-config-json.js .vercel/output/config.json",
    "website:prd": "pnpm run website:build && pnpm -F waku-website start"
  },
  "prettier": {
    "singleQuote": true,
    "plugins": [
      "prettier-plugin-tailwindcss"
    ],
    "tailwindConfig": "./packages/website/tailwind.config.js",
    "tailwindFunctions": [
      "cx"
    ],
    "overrides": [
      {
        "files": "**/*.jsonc",
        "options": {
          "trailingComma": "none"
        }
      }
    ]
  },
  "devDependencies": {
    "@actions/core": "^3.0.1",
    "@eslint/js": "9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "waku": "workspace:*"
  },
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215"
}
